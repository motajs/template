{
    "compilerOptions": {
        "target": "ESNext",
        "composite": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "allowSyntheticDefaultImports": true,
        "strict": true
    },
    "include": [
        "vite.config.ts",
        "script/**/*.ts",
        "docs/**/*.ts",
        "docs/.vitepress/api.ts",
        "docs/.vitepress/config.ts",
        "docs/.vitepress/apiSidebar.ts",
        "docs/.vitepress/init.ts"
    ]
}
